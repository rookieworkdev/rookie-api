# Server Configuration
PORT=8000
NODE_ENV=development

# OpenRouter Configuration (required — all AI calls route through OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI Configuration (optional — fallback if OpenRouter key is missing)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Resend Email Configuration (required)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
# Comma-separated list of allowed email recipients (leave empty to allow all)
EMAIL_WHITELIST=

# Admin Alerts (comma-separated for multiple recipients)
ADMIN_ALERT_EMAILS=admin@yourdomain.com,team@yourdomain.com

# Webhook Security
WEBHOOK_SECRET=your_webhook_secret_here

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,https://yourdomain.com

# Apify Configuration (for job scrapers)
APIFY_API_KEY=your_apify_api_key_here

# API key for all protected endpoints (admin, scrapers, etc.)
ROOKIE_API_KEY=your_rookie_api_key_here
SCRAPER_ENABLED=true
# Per-scraper kill switches. Default to true when unset.
# A scraper only runs when BOTH SCRAPER_ENABLED=true AND its own flag is true.
# Set one to `false` to pause that scraper without touching the others.
INDEED_ENABLED=true
LINKEDIN_ENABLED=true
AF_ENABLED=true
GOOGLEMAPS_ENABLED=true
SCRAPER_KEYWORDS=ekonom,ingenjör,tekniker,kundtjänst
SCRAPER_EXCLUSION_KEYWORDS=senior,chef,lead
SCRAPER_COUNTRY=SE
SCRAPER_MAX_ITEMS=50
JOB_RETENTION_DAYS=20
